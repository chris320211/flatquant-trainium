# Trainium2 Instance Configuration Template
# Copy this to .env and fill in your ANTHROPIC_API_KEY
# Then run: python agent/main.py <model-name>

# Required: Anthropic API key
ANTHROPIC_API_KEY=sk-...

# Optional: LLM model selection (defaults: planning=opus-4-6, codegen=sonnet-4)
# ANTHROPIC_MODEL_PLANNING=claude-opus-4-6-20250514
# ANTHROPIC_MODEL_CODEGEN=claude-sonnet-4-20250514

# ============================================================================
# Trainium2 Optimization Settings
# ============================================================================

# FlatQuant Calibration (optional)
# Skip by default. Set to "smoke" for light calibration or "full" for complete.
# Requires model weights and calibration data.
# FLATQUANT_CALIBRATE=smoke

# NxDI Code Generation Mode
# fast = simple LLM-based scaffolding (quick)
# full = detailed 4-phase skill-based generation (thorough, default)
TRAINIUM_SKILL_MODE=full

# ============================================================================
# Test Execution Settings (Trainium2 Specific)
# ============================================================================

# Run generated tests (recommended on Trainium instances)
# Includes: block tests, integration tests, weight mapping tests
TRAINIUM_RUN_TESTS=1

# Use Trainium XLA accelerator for tests (if available)
# Set to 0 to use CPU (slower but works anywhere)
TRAINIUM_USE_XLA=0

# ============================================================================
# Compilation Settings (Trainium2 Specific)
# ============================================================================

# Enable Neuron compilation with neuronx_compiler
# Set to 1 to attempt compilation after code generation
TRAINIUM_COMPILE=0

# Optional custom compile command (runs in output directory)
# Example: neuronx_compiler --input-names MODEL_INPUT -O2 --model-type llama nxdi/neuron_causal_lm.py
# TRAINIUM_COMPILE_CMD=

# ============================================================================
# Debugging & Advanced Options
# ============================================================================

# Verbose logging (optional)
# Set PYTHONUNBUFFERED=1 before running for real-time output
# export PYTHONUNBUFFERED=1

# HuggingFace Token (required for private models)
# HF_TOKEN=hf_...

# HuggingFace Cache Directory (where model weights are stored)
# HF_HOME=/home/ec2-user/.cache/huggingface

# ============================================================================
# Usage Examples on Trainium2
# ============================================================================

# 1. Basic: Generate FlatQuant + NxDI code only (no tests/compile)
#    export TRAINIUM_RUN_TESTS=0
#    export TRAINIUM_COMPILE=0
#    python agent/main.py mistralai/Mistral-7B-v0.1

# 2. With Test Generation (code + tests, but don't run them):
#    TRAINIUM_RUN_TESTS=0 python agent/main.py mistralai/Mistral-7B-v0.1

# 3. Full Testing (generate and execute tests on Trainium):
#    TRAINIUM_RUN_TESTS=1 TRAINIUM_USE_XLA=1 python agent/main.py mistralai/Mistral-7B-v0.1

# 4. With Compilation (generate code + test + compile):
#    TRAINIUM_RUN_TESTS=1 TRAINIUM_COMPILE=1 TRAINIUM_COMPILE_CMD="neuronx_compiler ..." \
#    python agent/main.py mistralai/Mistral-7B-v0.1

# 5. Full Calibration + NxDI (requires model weights):
#    FLATQUANT_CALIBRATE=smoke TRAINIUM_RUN_TESTS=1 python agent/main.py mistralai/Mistral-7B-v0.1
